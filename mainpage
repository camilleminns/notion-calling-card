<script>
  // ── VALUES DATA ──
  const values = [
    "Deep conversations", "Intellectual curiosity", "Loyalty", "Adventure",
    "Work-life balance", "Creativity", "Slow mornings", "Travel often",
    "Ambition", "Humor / levity", "Kindness as default", "Family",
    "Financial responsibility", "Personal growth", "Spirituality / faith",
    "Spontaneity", "Dogs (or pets generally)", "Physical health",
    "Alone time matters", "Big social circle", "Cooking / food culture",
    "Reading / books", "Music is essential", "Social impact work"
  ];

  // Highlight user's actual values (indices that apply to YOU)
  const myValueIndices = new Set([0,1,2,5,6,10,11,16,17,21,22]);

  const grid = document.getElementById('valuesGrid');
  const bar = document.getElementById('meterBar');
  const num = document.getElementById('meterNum');

  let checked = new Set();

  values.forEach((v, i) => {
    const item = document.createElement('div');
    item.className = 'value-item';
    item.innerHTML = `<div class="value-checkbox"></div><span class="value-label">${v}</span>`;
    item.addEventListener('click', () => {
      if (checked.has(i)) {
        checked.delete(i);
        item.classList.remove('checked');
        item.querySelector('.value-checkbox').textContent = '';
      } else {
        checked.add(i);
        item.classList.add('checked');
        item.querySelector('.value-checkbox').textContent = '✓';
      }
      updateMeter();
    });
    grid.appendChild(item);
  });

  function updateMeter() {
    // count overlap with MY values
    let overlap = [...checked].filter(i => myValueIndices.has(i)).length;
    const pct = Math.round((overlap / myValueIndices.size) * 100);
    bar.style.width = pct + '%';
    num.textContent = overlap;
  }

  // ── SCROLL ANIMATIONS ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>

